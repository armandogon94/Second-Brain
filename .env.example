# =============================================================================
# Second Brain — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Database (PostgreSQL 16 + pgvector)
DB_USER=armando
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=second_brain_db
DATABASE_URL=postgresql+asyncpg://armando:changeme_use_a_strong_password@postgres:5432/second_brain_db

# API Keys
OPENAI_API_KEY=sk-...                          # For text-embedding-3-small embeddings
ANTHROPIC_API_KEY=sk-ant-...                   # For Claude Haiku/Sonnet LLM

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...           # From @BotFather
TELEGRAM_USER_ID=123456789                     # Your Telegram user ID (for access control)
WEBHOOK_URL=https://telegram.brain.armandointeligencia.com/
WEBHOOK_SECRET=generate_a_random_string_here   # Prevents fake webhook updates

# Application
ENVIRONMENT=development                        # development | production
SECRET_KEY=generate_a_random_secret_key_here   # For session/token signing
LOG_LEVEL=INFO                                 # DEBUG | INFO | WARNING | ERROR

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8110       # Backend URL for frontend API calls

# Deployment (production only)
LETSENCRYPT_EMAIL=your_email@example.com       # For SSL certificate generation
